{
  "version": "2.0",
  "fixed_personas": [
    "eval_persona_a",
    "eval_persona_b",
    "eval_persona_c"
  ],
  "required_regression_suites": [
    "counterfactual_user",
    "counterfactual_persona",
    "longitudinal_state",
    "chat_evidence",
    "no_reply",
    "overreaction"
  ],
  "quality_dimensions": [
    "persona_differentiation",
    "interaction_sensitivity",
    "longitudinal_consistency",
    "style_similarity",
    "evidence_grounding",
    "response_action_accuracy",
    "overreaction_rate",
    "latency"
  ],
  "offline_release_gates": {
    "regression_pass_rate": 1.0,
    "max_normal_llm_calls": 2,
    "max_evaluator_retry": 1,
    "max_generator_retry": 1,
    "max_normal_state_delta": 0.15,
    "max_major_state_delta": 0.25,
    "consistency_score_threshold": 0.75,
    "max_retrieved_evidence": 5,
    "raw_sensitive_text_persisted": false
  },
  "live_release_gates": {
    "required": true,
    "environment": "staging",
    "measurements": [
      "persona_differentiation",
      "style_similarity",
      "evidence_grounding",
      "response_action_accuracy",
      "overreaction_rate",
      "p50_latency_ms",
      "p95_latency_ms"
    ]
  }
}
